@using UI.Authentication

@inject AuthenticationStateProvider authenticationStateProvider
@inject NavigationManager navigationManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">CRM</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass">
    <nav class="flex-column">

        <!-- Home -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="index" Match="NavLinkMatch.All">
                <span class="oi oi-home me-2"></span> @Translation.HomeNav
            </NavLink>
        </div>

        <!-- Customers -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="Customers/Customers">
                <span class="oi oi-people me-2"></span> @Translation.Customers
            </NavLink>
        </div>

        <!-- Orders -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="Orders/Orders">
                <span class="oi oi-clipboard me-2"></span> @Translation.Orders
            </NavLink>
        </div>

        <!-- User Management (collapsible section) -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" @onclick="ToggleUserManagement" style="cursor: pointer;">
                <div class="d-flex align-items-start" style="line-height: 1.1;">
                    <span class="oi oi-shield me-2 mt-1"></span> &nbsp;
                    <span class="text-break">@Translation.UserManagement</span>
                </div>
                <span class="oi @(isUserManagementOpen ? "oi-chevron-bottom" : "oi-chevron-right")"></span>
            </NavLink>

            @if (isUserManagementOpen)
            {
                <div class="ms-4">
                    <NavLink class="nav-link" href="UserManagment/Users">
                        <span class="oi oi-person me-2"></span> @Translation.Users
                    </NavLink>
                    <NavLink class="nav-link" href="UserManagment/UserRoles/Roles">
                        <span class="oi oi-lock-locked me-2"></span> @Translation.UserRoles
                    </NavLink>
                </div>
            }
        </div>

        <!-- Logout -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="Login" @onclick="Logout">
                <span class="oi oi-account-logout me-2"></span> @Translation.Logout
            </NavLink>
        </div>

    </nav>
</div>


@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private bool isUserManagementOpen = false;

    private void ToggleUserManagement()
    {
        isUserManagementOpen = !isUserManagementOpen;
    }

    private async void Logout()
    {
        var crmAuthenticationStateProvider = (CrmAuthenticationStateProvider)authenticationStateProvider;
        await crmAuthenticationStateProvider.Logout();
    }

}
