
@inject NavigationManager Navigation
@inject ICrmModalService ModalService
@inject AppConfig AppConfig
@inject ILoggingService LoggingService

@code {
    [Parameter] public Exception Exception { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (Exception is not null)
        {
            var logDetails = new LogDetails
            {
                Message = Exception.Message,
                StackTrace = ExceptionHelper.FlattenExceptionMessages(Exception),
                Url = new Uri(Navigation.Uri).PathAndQuery,
                LogLevel = "Error"
            };

            var isSuccess = await LoggingService.SendErrorLogToServerAsync(logDetails);

            if (!isSuccess)
            {
                Console.WriteLine("Failed to log exception to server.");
            }
        }

        if (AppConfig.IsDevelopment())
        {
            await ModalService.ShowErrorMessageAsync("An error occurred please try again");
        }
        else
        {
            await ModalService.ShowErrorMessageAsync(Exception.Message);
        }

        Navigation.NavigateTo("/index", forceLoad: true);
    }
}
