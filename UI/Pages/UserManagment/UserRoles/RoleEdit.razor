
@inject IRoleService roleService
@inject ICrmModalService modal

<h3 class="mb-4">Permissions for role: <span class="text-primary">@RoleName</span></h3>


<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Role Permissions - @RoleName</h5>
                </div>
                <div class="card-body">
                    <EditForm Model="rolePermissions" OnValidSubmit="UpdatePermissionsAsync">
                        <Permissions RoleName="@RoleName" @ref="permissions" />

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private BlazoredModalInstance BlazoredModal { get; set; }

    [Parameter]
    public string RoleName { get; set; } = string.Empty;

    private Permissions permissions = new();
    private Dictionary<string, bool> rolePermissions { get; set; } = new Dictionary<string, bool>();

    private async Task UpdatePermissionsAsync()
    {
        rolePermissions = permissions.RolePermissions
            .ToDictionary(x => x.Name, x => x.Value);

        var result = await roleService.UpdateRolePermissionsAsync(RoleName, rolePermissions);
        if (!result.IsSuccess)
        {
            modal.ShowErrorMessage(result.ErrorMessage);
            return;
        }

        await BlazoredModal.CloseAsync();
    }
}
