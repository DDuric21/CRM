@page "/customers"

<PageTitle>Customers</PageTitle>

@using UI.Services
@using Models.DTO
@inject ICustomerService _customerService

<h3>Customers</h3>

<p>This component demonstrates fetching customers data.</p>

@if (customers == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Address</th>
                <th>Birthday</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var customer in customers)
            {
                <tr>
                    <td>@customer.Name</td>
                    <td>@customer.Address?.FullAddress</td>
                    <td>@customer.Birthday</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<CustomerDTO> customers = new List<CustomerDTO>();

    protected override async Task OnInitializedAsync()
    {
        var asyncCustomers = await _customerService.GetCustomers();

        await foreach(var customer in asyncCustomers)
        {
            customers.Add(customer);
        }
    }
}
