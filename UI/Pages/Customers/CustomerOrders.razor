
@inject ICustomerService customerService
@inject NavigationManager navigationManager

<table class="table table-hover">
    <thead>
        <tr>
            <th>@Translation.OrderID</th>
            <th>@Translation.AssetName</th>
            <th>@Translation.Created</th>
            <th>@Translation.Submited</th>
            <th>@Translation.CreatedBy</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var orderDTO in orders)
        {
            <tr role="button" @ondblclick="() => RedirectToOrder(orderDTO.OrderID)">
                <td><label id="@orderDTO.OrderID" >@orderDTO.OrderID</label></td>
                <td><label id="@orderDTO.OrderID" >@orderDTO.AssetDTO.Name</label></td>
                <td><label id="@orderDTO.OrderID" >@orderDTO.DateCreated.ToStringValue()</label></td>
                <td><label id="@orderDTO.OrderID" >@orderDTO.DateSubmited.ToStringValue()</label></td>
                <td><label id="@orderDTO.OrderID" >@orderDTO.CreatedByUsername</label></td>
            </tr>
        }
    </tbody>
</table>




@code {
    [CascadingParameter]
    public CustomerDTO CustomerDTO { get; set; }

    private SortedSet<OrderDTO> orders = new SortedSet<OrderDTO>(new OrdersSorter());

    protected override async Task OnInitializedAsync()
    {        
        var customerOrders = await customerService.GetCustomerOrdersAsync(CustomerDTO.Id);

        foreach(var order in customerOrders)
        {
            orders.Add(order);
        }
    }

    private void RedirectToOrder(Guid id)
    {
        navigationManager.NavigateTo($"/Orders/Order?orderID={id}&readOrder={true}");
    }

}
