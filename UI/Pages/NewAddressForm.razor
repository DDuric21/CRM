
@inject IAddressService addressService
@inject ICrmModalService modalService

<div class="modal-body" style="padding-top: 0; margin-top:-1.5rem;">
    <div class="container mt-0">
        <div class="row justify-content-center">
            <div class="col-md-8" style="min-width: 600px;">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">@Translation.CreateNewAddress</h5>
                    </div>
                    <div class="card-body">
                        <EditForm Model="newAddress" OnValidSubmit="CreateAddressAsync">
                            <DataAnnotationsValidator />

                            <div class="mb-3">
                                <label class="form-label">@Translation.Country</label>
                                <InputText class="form-control" @bind-Value="newAddress.Country" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">@Translation.AddressCity</label>
                                <InputText class="form-control" @bind-Value="newAddress.City" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">@Translation.PostalCode</label>
                                <InputNumber class="form-control" @bind-Value="newAddress.PostalCode" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">@Translation.Address</label>
                                <InputText class="form-control" @bind-Value="newAddress.Address" />
                            </div>

                            <ValidationSummary />

                            <div class="mb-3">
                                <label class="form-label">@Translation.FullAddress</label>
                                <input type="text" class="form-control" value="@fullAddress" disabled />
                            </div>

                            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                <button type="button" class="btn btn-secondary me-2" @onclick="Cancel">@Translation.Cancel</button>
                                <button type="submit" class="btn btn-primary">@Translation.Create</button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    BlazoredModalInstance modalInstance { get; set; }

    [Parameter] 
    public long CustomerId { get; set; }

    private AddressDTO addressDTO = new AddressDTO();
    private NewAddress newAddress = new NewAddress();
    private string fullAddress => $"{newAddress.Address}, {newAddress.PostalCode}, {newAddress.City}, {newAddress.Country}";

    protected override async Task OnInitializedAsync()
    {        
        addressDTO.CustomerId = CustomerId;
        modalInstance.Title = Translation.CreateNewAddress;
    }

    protected async Task Cancel() => await modalInstance.CancelAsync();

    protected async Task CreateAddressAsync()
    {
        addressDTO.FullAddress = fullAddress;
        var result = await addressService.CreateNewAddressAsync(addressDTO);

        if (result.IsNullOrEmpty())
        {
            modalService.ShowErrorMessage(Translation.AddressNotCreated);
            Cancel();
            return;
        }

        modalService.ShowSuccessToast(Translation.AddressAddedSuccess);
        await modalInstance.CloseAsync(ModalResult.Ok(result));
    }
}
