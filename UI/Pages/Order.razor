@page "/order"

@inject ILocalStorageService localStorageService
@inject NavigationManager navigationManager
@inject IOrderService orderService
@inject ICustomerService customerService
@inject ICrmModalService modalService

@if (customerDTO == null)
{
    <Loader></Loader>
}
else
{
    <fieldset disabled="@IsDisabled()">
        <h1>@customerDTO.Name</h1>
        <br />

        <div class="align-items-stretch">
            <input type="text" @bind-value="customerDTO.Name" />
            <input type="text" @bind-value="customerDTO.Birthday" />
            <button type="submit" name="submit" class="btn btn-primary" @onclick="SubmitOrder" >SubmitOrder</button>
        </div>

        <CascadingValue Value="@orderDTO">
            <Asset AssetDTO="orderDTO.AssetDTO" ActionID="actionID" @ref="orderAsset"></Asset>
        </CascadingValue>
    </fieldset>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "orderID")]
    public Guid OrderID { get; set; }
    private OrderDTO orderDTO { get; set; } = new OrderDTO();
    private Asset orderAsset = new Asset();

    [Parameter]
    [SupplyParameterFromQuery(Name = "customerID")]
    public long CustomerID { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "action")]
    public string Action { get; set; } = string.Empty;

    [Parameter]
    [SupplyParameterFromQuery(Name = "readOrder")]
    public bool ReadOrder { get; set; }

    private int actionID => DetermineAction(); 

    private CustomerDTO customerDTO;

    protected override async Task OnInitializedAsync()
    {
        if (ReadOrder)
        {
            orderDTO = await orderService.GetOrderDataAsync(OrderID);
            customerDTO = orderDTO.CustomerDTO;
        }
        else
        {
            customerDTO = await localStorageService.GetItemAsync<CustomerDTO>(OrderID.ToString());            
        }

        if (customerDTO.IsNullOrEmpty()
            && orderDTO.CustomerDTO.IsNullOrEmpty())
        {
            navigationManager.NavigateTo($"/Customers/{CustomerID}");
        }

        if (orderDTO.OrderID == Guid.Empty)
        {
            orderDTO.OrderID = this.OrderID;            
        }

        if (orderDTO.CustomerDTO.IsNullOrEmpty())
        {
            orderDTO.CustomerDTO = this.customerDTO;            
        }

        if (!string.IsNullOrWhiteSpace(Action))
        {
            (var actionID , var customerAssetID) = ParseActionParameter();
            orderDTO.AssetDTO = await customerService.GetCustomerAssetDataAsync(customerAssetID);
        }

        SetOrderAction();
    }

    private async Task SubmitOrder()
    {
        orderDTO.AssetDTO = orderAsset.AssetDTO;

        var response = await orderService.SubmitOrderAsync(orderDTO);

        if (response <= 0)
        {
            modalService.ShowErrorMessage("Order not submitted successfully");
        }
        else
        {
            await modalService.ShowDialog("Order successfully submitted", ModalDialogType.OK);
            navigationManager.NavigateTo($"/Customers/{customerDTO.Id}");
        }
    }

    private void SetOrderAction()
    {
        if ((int)orderDTO.Action <= 0)
        {
            orderDTO.Action = actionID > 0
            ? (CrudAction)actionID
            : CrudAction.Create;
        }
    }

    private (int, long) ParseActionParameter()
    {
        var actionID = 0;
        var customerAssetID = 0L; 
        if (string.IsNullOrWhiteSpace(Action))
        {
            return (actionID, customerAssetID);            
        }

        string[] ids = Action.Split(":");
        int.TryParse(ids[0], out actionID);
        long.TryParse(ids[1], out customerAssetID);

        return (actionID, customerAssetID);
    }

    private int DetermineAction()
    {
        if (ReadOrder)
        {
            return (int)orderDTO.Action;
        }

        return ParseActionParameter().Item1;
    }

    private bool IsDisabled()
    {
        var openOrderStatuses = new List<int> { 0, (int)OrderStatus.Open };
        var isDisabled = !openOrderStatuses.Contains((int)orderDTO.OrderStatus);

        return isDisabled;
    }
}
